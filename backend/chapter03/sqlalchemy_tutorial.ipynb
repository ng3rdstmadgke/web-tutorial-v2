    "\n",
    "    # cascade=\"all, delete-orphan\" の効果で、id = 1 に紐づくアイテムも削除されている\n",
    "    items = session.execute(select(Item)).scalars().all()\n",
    "    print([f\"id={item.id}, title={item.title}, content={item.content}\" for item in items])"
   ]
