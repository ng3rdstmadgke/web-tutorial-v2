      "[<Role(id=1, name=RoleType.SYSTEM_ADMIN)>, <Role(id=2, name=RoleType.LOCATION_ADMIN)>, <Role(id=3, name=RoleType.LOCATION_OPERATOR)>]\n"
     ]
    }
   ],
   "source": [
    "# 登録したデータを確認\n",
    "from sqlalchemy import select\n",
    "\n",
    "with SessionLocal() as session:\n",
    "    print(session.execute(select(User)).scalars().all())\n",
    "    print(session.execute(select(Role)).scalars().all())"
   ]
