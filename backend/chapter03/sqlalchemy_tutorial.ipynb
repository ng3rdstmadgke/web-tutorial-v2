  {
   "cell_type": "markdown",
   "id": "c1015280-341d-4bce-a243-83c39f1c6f45",
   "metadata": {},
   "source": [
    "# 4.8 データの更新"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "816aa739-306a-409f-9215-3ebe8f3681ab",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "2026-05-08 12:15:20.010500+00:00 2026-05-08 12:15:28.561267+00:00\n"
     ]
    }
   ],
   "source": [
    "with SessionLocal() as session:\n",
    "    try:\n",
    "        # sato を midorikawa に変更\n",
    "        sato = session.execute(select(User).where(User.id == 2)).scalar_one()\n",
    "        sato.username = \"midorikawa\"\n",
    "        session.add(sato)\n",
    "        session.commit()\n",
    "        # session.refresh() で DB から最新の値を取り直す\n",
    "        # (DB トリガーが書き換えた updated を Python 側に反映するため)\n",
    "        session.refresh(sato)\n",
