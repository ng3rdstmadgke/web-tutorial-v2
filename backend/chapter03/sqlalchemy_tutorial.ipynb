   "cell_type": "markdown",
   "id": "445488a8-69bc-446e-9fe6-f5aaa5fa47e5",
   "metadata": {},
   "source": [
    "## 1 対多のリレーションを持つ items への追加"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "8401c41a-6b4e-45c1-8cf8-085a1f5a52f4",
   "metadata": {},
   "source": [
    "#### 方法 1: `user_id` を指定して登録"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "4ec0cde4-7734-4b89-9470-92c5c82f740a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[<Item(id=1, user_id=1, title=a, content=foo)>]\n"
     ]
    }
   ],
   "source": [
    "with SessionLocal() as session:\n",
    "    try:\n",
    "        # yamada にアイテムを追加\n",
    "        yamada = session.execute(\n",
    "            select(User).where(User.id == 1)\n",
    "        ).scalar_one()\n",
    "        item = Item(title=\"a\", content=\"foo\", user_id=yamada.id)\n",
    "        session.add(item)\n",
    "        session.commit()\n",
    "        session.refresh(yamada)  # レコードのデータを最新に更新\n",
    "        print(yamada.items)\n",
    "    except Exception as e:\n",
    "        session.rollback()\n",
    "        raise e"
   ]
  },
  {
